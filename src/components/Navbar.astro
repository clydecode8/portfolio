---
import { site } from "../data/site";

const links = [
  { href: "/#about", label: "About" },
  { href: "/#experience", label: "Journey" },
  { href: "/#skills", label: "Toolkit" },
  { href: "/#projects", label: "Work" },
];
---

<header class="fixed inset-x-0 top-6 z-50 px-4">
  <nav class="mx-auto flex h-[70px] max-w-7xl items-center justify-between rounded-full border border-sky-100 bg-white/85 px-6 shadow-[0_20px_60px_rgba(14,165,233,.12)] backdrop-blur-xl sm:px-10">
    
    <a href="/" aria-label="Go home" class="flex items-center gap-3">
      <img 
        src="/favicon.svg" 
        alt="Logo" 
        class="h-10 w-10 rounded-full object-cover"
      />
    </a>

    <ul class="hidden items-center gap-10 text-sm font-bold text-slate-800 md:flex">
      {links.map((link) => (
        <li>
          <a class="transition hover:text-sky-500" href={link.href}>
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <a
      href={`mailto:${site.email}`}
      class="rounded-full bg-sky-400 px-6 py-3 text-sm font-black uppercase tracking-wide text-white transition hover:-translate-y-0.5 hover:bg-sky-500 hover:shadow-[0_16px_35px_rgba(14,165,233,.25)]"
    >
      Contact
    </a>
  </nav>
</header>