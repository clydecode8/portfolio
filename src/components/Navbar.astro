---
import { site } from "../data/site";

const links = [
  { href: "/#about", label: "About" },
  { href: "/#experience", label: "Journey" },
  { href: "/#skills", label: "Toolkit" },
  { href: "/#projects", label: "Work" },
];
---

<header class="fixed inset-x-0 top-3 z-50 px-3 sm:top-6 sm:px-4">
  <nav
    class="
      mx-auto
      max-w-7xl
      rounded-[1.7rem]
      border
      border-sky-100
      bg-white/95
      px-4
      py-3
      shadow-[0_20px_60px_rgba(14,165,233,.12)]
      backdrop-blur-xl

      sm:rounded-full
      sm:px-10
      sm:py-4
    "
  >
    <!-- Top row -->
    <div class="flex items-center justify-between gap-4">
      <a href="/" aria-label="Go home" class="flex shrink-0 items-center gap-3">
        <img
          src="/favicon.svg"
          alt="Logo"
          class="h-10 w-10 rounded-full object-cover"
        />
      </a>

      <!-- Desktop links -->
      <ul class="hidden items-center gap-8 font-mono text-sm font-bold text-slate-800 md:flex lg:gap-10">
        {links.map((link) => (
          <li>
            <a class="transition hover:text-sky-500" href={link.href}>
              {link.label}
            </a>
          </li>
        ))}
      </ul>

      <a
        href={`mailto:${site.email}`}
        class="
          rounded-full
          bg-sky-500
          px-4
          py-2
          font-mono
          text-xs
          font-black
          uppercase
          tracking-wide
          text-white
          transition
          hover:-translate-y-0.5
          hover:bg-sky-600
          hover:shadow-[0_16px_35px_rgba(14,165,233,.25)]

          sm:px-6
          sm:py-3
          sm:text-sm
        "
      >
        Contact
      </a>
    </div>

    <!-- Mobile links -->
    <ul
      class="
        mt-3
        grid
        grid-cols-4
        gap-2
        border-t
        border-slate-200
        pt-3

        font-mono
        text-[10px]
        font-black
        uppercase
        tracking-wide
        text-slate-700

        md:hidden
      "
    >
      {links.map((link) => (
        <li>
          <a
            class="
              flex
              justify-center
              rounded-full
              bg-sky-50
              px-2
              py-2
              transition
              active:scale-95
              hover:bg-sky-100
              hover:text-sky-600
            "
            href={link.href}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>