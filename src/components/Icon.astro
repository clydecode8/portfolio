---
export interface Props {
  name: string;
  class?: string;
}
const { name, class: className = "h-5 w-5" } = Astro.props;
const attrs = { class: className, viewBox: "0 0 24 24", fill: "none", stroke: "currentColor", "stroke-width": "2", "stroke-linecap": "round", "stroke-linejoin": "round" };
---
{ name === "spark" && <svg {...attrs}><path d="M12 3l1.8 5.2L19 10l-5.2 1.8L12 17l-1.8-5.2L5 10l5.2-1.8L12 3z"/><path d="M19 15l.8 2.2L22 18l-2.2.8L19 21l-.8-2.2L16 18l2.2-.8L19 15z"/></svg> }
{ name === "briefcase" && <svg {...attrs}><path d="M10 6V5a2 2 0 0 1 2-2h0a2 2 0 0 1 2 2v1"/><rect x="3" y="6" width="18" height="14" rx="2"/><path d="M3 12h18"/><path d="M9 12v2h6v-2"/></svg> }
{ name === "layers" && <svg {...attrs}><path d="M12 2l9 5-9 5-9-5 9-5z"/><path d="M3 12l9 5 9-5"/><path d="M3 17l9 5 9-5"/></svg> }
{ name === "bot" && <svg {...attrs}><rect x="5" y="8" width="14" height="10" rx="3"/><path d="M12 8V4"/><path d="M8 12h.01"/><path d="M16 12h.01"/><path d="M9 16h6"/></svg> }
{ name === "bank" && <svg {...attrs}><path d="M3 10h18"/><path d="M5 10v8"/><path d="M9 10v8"/><path d="M15 10v8"/><path d="M19 10v8"/><path d="M3 18h18"/><path d="M12 3l9 5H3l9-5z"/></svg> }
{ name === "shield" && <svg {...attrs}><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg> }
{ name === "chart" && <svg {...attrs}><path d="M4 19V5"/><path d="M4 19h16"/><path d="M8 15l3-3 3 2 5-7"/></svg> }
{ name === "rocket" && <svg {...attrs}><path d="M4.5 16.5c-1 1-1.5 3-1.5 4.5 1.5 0 3.5-.5 4.5-1.5"/><path d="M9 15l-4-4 6-6c3-3 7-3 9-1-2 2-2 6-1 9l-6 6-4-4z"/><path d="M14 8h.01"/></svg> }
{ name === "code" && <svg {...attrs}><path d="M16 18l6-6-6-6"/><path d="M8 6l-6 6 6 6"/><path d="M14 4l-4 16"/></svg> }
{ name === "database" && <svg {...attrs}><ellipse cx="12" cy="5" rx="8" ry="3"/><path d="M4 5v6c0 1.7 3.6 3 8 3s8-1.3 8-3V5"/><path d="M4 11v6c0 1.7 3.6 3 8 3s8-1.3 8-3v-6"/></svg> }
{ name === "flame" && <svg {...attrs}><path d="M12 22c4 0 7-3 7-7 0-4-3-7-4-10-1 3-3 4-5 6 0-2-.5-3.5-2-5-1 3-3 5-3 9 0 4 3 7 7 7z"/></svg> }
{ name === "globe" && <svg {...attrs}><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15 15 0 0 1 0 20"/><path d="M12 2a15 15 0 0 0 0 20"/></svg> }
{ name === "mail" && <svg {...attrs}><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg> }
{ name === "user" && <svg {...attrs}><path d="M20 21a8 8 0 0 0-16 0"/><circle cx="12" cy="7" r="4"/></svg> }
{ name === "zap" && <svg {...attrs}><path d="M13 2L3 14h8l-1 8 10-12h-8l1-8z"/></svg> }
