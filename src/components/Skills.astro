---
import { languages, tools } from "../data/skills";
const groups = [
  { title: "Languages & Frameworks", icon: "</>", items: languages },
  { title: "Tools & Software", icon: "⚒", items: tools },
];
---
<section id="skills" class="bg-[#f7fbff] px-6 py-24 sm:px-10">
  <div class="mx-auto max-w-7xl">
    <div class="mb-12">
      <p class="text-sm font-black uppercase tracking-[0.25em] text-sky-500">
        Toolkit
      </p>
      <h2 class="mt-3 text-4xl font-black text-slate-950">
        What I work with
      </h2>
    </div>

    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {[
        { name: "React", icon: "/icons/react.svg", type: "Frontend" },
        { name: "Tailwind CSS", icon: "/icons/tailwind.svg", type: "UI Styling" },
        { name: "Node.js", icon: "/icons/node.svg", type: "Backend" },
        { name: "Java", icon: "/icons/java.svg", type: "Backend" },
        { name: "Spring Boot", icon: "/icons/spring.svg", type: "Backend" },
        { name: "Python", icon: "/icons/python.svg", type: "AI / Scripts" },
        { name: "Docker", icon: "/icons/docker.svg", type: "DevOps" },
        { name: "Git", icon: "/icons/git.svg", type: "Version Control" },
      ].map((skill) => (
        <div class="group rounded-[2rem] border border-sky-100 bg-white p-6 shadow-sm transition duration-300 hover:-translate-y-2 hover:shadow-[0_24px_60px_rgba(14,165,233,.12)]">
          <div class="mb-6 flex h-14 w-14 items-center justify-center rounded-2xl bg-sky-50">
            <img src={skill.icon} alt={skill.name} class="h-8 w-8 object-contain" />
          </div>

          <h3 class="text-xl font-black text-slate-950">
            {skill.name}
          </h3>

          <p class="mt-2 text-sm font-semibold text-slate-500">
            {skill.type}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>