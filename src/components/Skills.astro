---

<section id="skills" class="bg-[#FDFBF7] px-5 py-20 sm:px-10 sm:py-24">
  <div class="mx-auto max-w-7xl">
    <!-- Header -->
    <div class="reveal mb-12 grid gap-5 lg:grid-cols-[0.75fr_1.25fr] lg:items-end">
      <div class="min-w-0">
        <p class="font-mono text-xs font-black uppercase tracking-[0.25em] text-purple-600">
          Toolkit
        </p>

        <h2 class="mt-3 font-display text-4xl font-black tracking-[-0.05em] text-slate-950 sm:text-6xl">
          What I work with
        </h2>
      </div>

      <p class="max-w-2xl text-base leading-7 text-slate-600 lg:ml-auto">
        Click each category to explore my stack without turning the page into a long wall of logos.
      </p>
    </div>

    <!-- Accordion -->
    <div class="grid gap-5">
      {skillGroups.map((group, index) => (
        <div
          class={`
            reveal
            skill-accordion
            group

            overflow-hidden
            rounded-[1.8rem]
            border-2
            border-slate-900

            bg-white

            shadow-[6px_6px_0_#a855f7]

            transition
            duration-300

            hover:-translate-y-1
            hover:shadow-[8px_8px_0_#a855f7]

            ${index === 0 ? "is-open" : ""}
          `}
        >

          <!-- Header -->
          <button
            type="button"
            class="
              accordion-trigger

              flex
              w-full
              cursor-pointer
              items-center
              justify-between
              gap-5

              p-5
              text-left
              outline-none

              sm:p-7
            "
          >

            <div class="flex min-w-0 items-center gap-3">

              <div
                class="
                  grid
                  h-12
                  w-12
                  shrink-0
                  place-items-center

                  rounded-2xl
                  border-2
                  border-slate-900

                  bg-white

                  shadow-[3px_3px_0_#111827]

                  transition
                  duration-300

                  group-[.is-open]:rotate-6
                  group-[.is-open]:bg-purple-50
                "
              >

                <img
                  src={group.icon}
                  alt={group.title}
                  class="
                    h-7
                    w-7
                    object-contain
                  "
                />

              </div>


              <div>
                <h3 class="font-display text-xl font-black text-slate-950 sm:text-2xl">
                  {group.title}
                </h3>

                <p class="mt-1 text-sm leading-6 text-slate-500">
                  {group.subtitle}
                </p>
              </div>

            </div>


            <div class="flex shrink-0 items-center gap-3">

              <span
                class="
                  hidden

                  font-mono
                  text-[10px]
                  font-black
                  uppercase
                  tracking-[0.16em]
                  text-purple-600

                  sm:inline-flex
                "
              >
                Press me →
              </span>


              <span
                class="
                  hidden
                  min-[320px]:grid

                  h-10
                  w-10
                  shrink-0
                  place-items-center

                  rounded-full
                  border-2
                  border-slate-900

                  bg-purple-600

                  text-xl
                  font-black
                  text-white

                  shadow-[3px_3px_0_#111827]

                  transition
                  duration-300

                  group-[.is-open]:rotate-45
                  group-[.is-open]:bg-slate-900
                "
              >
                +
              </span>

            </div>

          </button>


          <!-- Content -->
          <div class="accordion-content overflow-hidden">

            <div class="border-t border-slate-900/10 px-5 pb-6 sm:px-7">

              <div
  class={`
    mt-5
    grid
    gap-3
    ${group.type === "language"
      ? "grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5"
      : "grid-cols-[repeat(auto-fit,minmax(95px,1fr))]"
    }
  `}
>

                {group.items.map((skill) => (
  group.type === "language" ? (

    <div class="rounded-2xl border border-slate-200 bg-white p-4 shadow-[4px_4px_0_#a855f7]">
      <div class="flex items-center justify-between gap-3">
        <div class="min-w-0">
          <p class="truncate font-mono text-sm font-black text-slate-900">
            {skill.name}
          </p>

          <p class="truncate text-xs font-bold text-purple-600">
            {skill.level}
          </p>
        </div>

        <span class="shrink-0 rounded-full bg-purple-100 px-2 py-1 font-mono text-[10px] font-black text-purple-700">
          {skill.percent}
        </span>
      </div>

      <div class="mt-4 h-2 w-full overflow-hidden rounded-full bg-slate-200">
        <div
          class="h-full rounded-full bg-purple-500"
          style={`width: ${skill.percent}; max-width: 100%;`}
        ></div>
      </div>
    </div>

  ) : (

    <div class="rounded-2xl border border-slate-900/10 bg-white p-4 text-center transition duration-300 hover:-translate-y-1 hover:border-slate-900 hover:shadow-[4px_4px_0_#111827]">
      <div class="mx-auto grid h-12 w-12 place-items-center rounded-2xl bg-[#FDFBF7]">
        <img
          src={skill.icon}
          alt={skill.name}
          class="h-8 w-8 object-contain"
        />
      </div>

      <p class="mt-3 break-words font-mono text-xs font-black text-slate-700">
        {skill.name}
      </p>
    </div>

  )
))}

              </div>

            </div>

          </div>


        </div>
      ))}
    </div>
</section>
<style>
.accordion-content {
  max-height: 0;
  transition:
    max-height 500ms ease,
    opacity 300ms ease;

  opacity: 0;
}

.skill-accordion.is-open .accordion-content {
  opacity: 1;
}
</style>
<script>
  
  
document.querySelectorAll(".skill-accordion").forEach((accordion, index) => {
  const button = accordion.querySelector(".accordion-trigger");
  const content = accordion.querySelector(".accordion-content");

  if (!button || !content) return;

  if (index === 0) {
    content.style.maxHeight = content.scrollHeight + "px";
  }

  button.addEventListener("click", () => {
    const open = accordion.classList.contains("is-open");

    if (open) {
      content.style.maxHeight = content.scrollHeight + "px";

      requestAnimationFrame(() => {
        content.style.maxHeight = "0px";
      });

      accordion.classList.remove("is-open");
    } 
    
    else {
      accordion.classList.add("is-open");

      content.style.maxHeight =
        content.scrollHeight + "px";
    }
  });
});
</script>