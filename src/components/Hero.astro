---
import { site } from "../data/site";
---

<section class="relative min-h-screen overflow-hidden bg-[#dff4ff] px-6 pt-32 sm:px-10">
  <div class="mx-auto grid max-w-7xl items-center gap-12 lg:grid-cols-[1.05fr_.95fr]">
    
    <div class="space-y-8">
      <p class="inline-flex rounded-full bg-white/70 px-5 py-2 text-sm font-bold text-sky-600 shadow-sm">
        Software Engineer Graduate
      </p>

      <div class="space-y-5">
        <h1 class="max-w-3xl text-5xl font-black leading-tight tracking-tight text-slate-950 sm:text-7xl">
          Building useful software with a clean engineering mindset.
        </h1>

        <p class="max-w-2xl text-lg leading-8 text-slate-600">
          I work across full-stack development, AI systems, backend services, and production-style engineering practices.
        </p>
      </div>

      <div class="flex flex-wrap gap-4">
        <a href="#projects" class="rounded-full bg-slate-950 px-7 py-4 text-sm font-black text-white transition hover:-translate-y-1 hover:bg-sky-500">
          View Work
        </a>

        <a href="#experience" class="rounded-full bg-white px-7 py-4 text-sm font-black text-slate-900 shadow-sm transition hover:-translate-y-1">
          My Journey
        </a>
      </div>
    </div>

    <div class="relative mx-auto w-full max-w-md">
      <div class="absolute -inset-6 rounded-[3rem] bg-white/60 blur-2xl"></div>

      <div class="relative overflow-hidden rounded-[3rem] border border-white/70 bg-white p-4 shadow-[0_30px_80px_rgba(14,165,233,.18)]">
        <img 
          src="/han.jpeg" 
          alt="Clyde Han" 
          class="h-[520px] w-full rounded-[2.4rem] object-cover"
        />
      </div>
    </div>

  </div>
</section>

<section id="experience" class="bg-white px-6 py-24 sm:px-10">
  <div class="mx-auto max-w-6xl">
    <div class="mb-14 max-w-2xl">
      <p class="mb-3 text-sm font-black uppercase tracking-[0.25em] text-sky-500">
        My journey
      </p>
      <h2 class="text-4xl font-black text-slate-950 sm:text-5xl">
        From learning software to working around real systems.
      </h2>
    </div>

    <div class="relative border-l-2 border-sky-100 pl-8">
      
      <div class="mb-12">
        <div class="absolute -left-[11px] h-5 w-5 rounded-full bg-sky-400 ring-8 ring-sky-50"></div>
        <p class="text-sm font-bold text-sky-500">2025</p>
        <h3 class="mt-2 text-2xl font-black text-slate-950">
          Software Engineer Intern · iFAST
        </h3>
        <p class="mt-3 max-w-2xl text-slate-600">
          Worked around banking-related systems, API testing, backend services, CI/CD workflows, logs, and production-style debugging.
        </p>
      </div>

      <div class="mb-12">
        <div class="absolute -left-[11px] h-5 w-5 rounded-full bg-sky-400 ring-8 ring-sky-50"></div>
        <p class="text-sm font-bold text-sky-500">2026</p>
        <h3 class="mt-2 text-2xl font-black text-slate-950">
          AI Interview Assistant
        </h3>
        <p class="mt-3 max-w-2xl text-slate-600">
          Built a resume-aware AI interview system using RAG, embeddings, vector search, and LLM evaluation.
        </p>
      </div>

      <div>
        <div class="absolute -left-[11px] h-5 w-5 rounded-full bg-sky-400 ring-8 ring-sky-50"></div>
        <p class="text-sm font-bold text-sky-500">Now</p>
        <h3 class="mt-2 text-2xl font-black text-slate-950">
          Full-stack + AI engineering focus
        </h3>
        <p class="mt-3 max-w-2xl text-slate-600">
          Improving my portfolio, building stronger projects, and preparing for software engineering roles.
        </p>
      </div>

    </div>
  </div>
</section>
