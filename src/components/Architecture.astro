---
const compare = [
  { label: "Normal prompting", items: ["Generic questions", "More context noise", "Harder to measure relevance"] },
  { label: "RAG approach", items: ["Retrieves resume evidence", "Focuses the prompt", "Can be evaluated with retrieval metrics"] },
];
const system = ["React UI", "Express API", "Resume Parser", "Embedding Model", "Pinecone", "Retriever", "Gemini LLM", "DeepEval"];
---

<section id="architecture" class="container-pad py-24">
  <p class="section-label mb-4">// 05_system_thinking</p>
  <h2 class="font-display text-3xl font-semibold tracking-tight text-graphite dark:text-cloud sm:text-4xl">
    Visual proof that I understand the system, not just the tools.
  </h2>

  <div class="mt-12 grid gap-6 lg:grid-cols-[1.15fr_0.85fr]">
    <div class="card p-6 sm:p-8">
      <p class="mb-6 font-mono text-xs uppercase tracking-[0.15em] text-ash dark:text-slate">AI Interview Platform — System Map</p>
      <div class="overflow-x-auto">
        <div class="flex min-w-[780px] items-center gap-3">
          {system.map((node, i) => (
            <>
              <div class="flex min-h-[86px] w-28 flex-shrink-0 flex-col justify-center rounded-xl border border-line-light bg-paper-softer p-3 text-center dark:border-line-dark dark:bg-ink-softer">
                <span class="font-mono text-[10px] text-copper">0{i + 1}</span>
                <span class="mt-1 font-display text-sm font-semibold leading-tight text-graphite dark:text-cloud">{node}</span>
              </div>
              {i < system.length - 1 && (
                <svg class="h-4 w-4 flex-shrink-0 text-copper" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7" /></svg>
              )}
            </>
          ))}
        </div>
      </div>
    </div>

    <div class="card p-6 sm:p-8">
      <p class="font-mono text-xs uppercase tracking-[0.15em] text-ash dark:text-slate">Why it matters</p>
      <div class="mt-6 space-y-4">
        {compare.map((block, index) => (
          <div class={`rounded-xl border p-4 ${index === 0 ? "border-line-light bg-paper-softer dark:border-line-dark dark:bg-ink-softer" : "border-copper/30 bg-copper/5"}`}>
            <p class={`font-display text-base font-semibold ${index === 0 ? "text-graphite dark:text-cloud" : "text-copper"}`}>{block.label}</p>
            <ul class="mt-3 space-y-2">
              {block.items.map((item) => (
                <li class="flex gap-2 text-sm text-ash dark:text-slate"><span class="text-copper">•</span><span>{item}</span></li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
