---
import Icon from "./Icon.astro";
const signals = [
  { icon: "bank", label: "Banking domain", note: "Open Banking and payment-related exposure" },
  { icon: "shield", label: "API quality", note: "Postman regression checks and debugging" },
  { icon: "chart", label: "Performance view", note: "JMeter load testing scenarios" },
  { icon: "rocket", label: "Delivery flow", note: "Jenkins and ArgoCD visibility" },
];
const timeline = [
  { icon: "code", label: "Software Engineering" },
  { icon: "shield", label: "Blockchain FYP" },
  { icon: "briefcase", label: "iFAST Internship" },
  { icon: "bot", label: "AI Interview Product" },
];
---

<section id="experience" class="container-pad py-24">
  <div class="reveal grid gap-8 lg:grid-cols-[0.8fr_1.2fr] lg:items-center">
    <div>
      <p class="section-label mb-4"><Icon name="briefcase" class="h-4 w-4" /> My journey</p>
      <h2 class="font-display text-3xl font-semibold tracking-tight text-graphite dark:text-cloud sm:text-4xl">
        A path from university projects to real engineering teams.
      </h2>
      <p class="mt-4 max-w-md text-base leading-relaxed text-ash dark:text-slate">
        I use my internship exposure as the baseline for how I build projects: clearer flows, testing awareness, and practical trade-offs.
      </p>
    </div>

    <div class="card overflow-hidden p-4 sm:p-6 soft-hover">
      <div class="grid gap-4 sm:grid-cols-4">
        {timeline.map((item) => (
          <div class="relative rounded-2xl bg-paper-softer p-4 text-center dark:bg-ink-softer">
            <div class="mx-auto grid h-10 w-10 place-items-center rounded-2xl bg-white text-copper shadow-sm">
              <Icon name={item.icon} class="h-5 w-5" />
            </div>
            <p class="mt-3 font-display text-sm font-semibold text-graphite dark:text-cloud">{item.label}</p>
          </div>
        ))}
      </div>

      <div class="mt-5 rounded-3xl bg-white p-5 shadow-sm dark:bg-white">
        <div class="flex flex-wrap items-center justify-between gap-2">
          <h3 class="font-display text-xl font-semibold text-graphite">Software Engineer Intern — iFAST</h3>
          <span class="rounded-full bg-violet/10 px-3 py-1 text-xs font-semibold text-violet">Production-aware</span>
        </div>
        <div class="mt-5 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
          {signals.map((item) => (
            <div class="rounded-2xl border border-line-light p-4">
              <Icon name={item.icon} class="h-6 w-6 text-copper" />
              <p class="mt-3 font-display text-sm font-semibold text-graphite">{item.label}</p>
              <p class="mt-1 text-xs leading-relaxed text-ash">{item.note}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
