---
const timeline = [
  {
    command: "start education --software-engineering",
    output: "Built fundamentals through software engineering coursework, team projects, and practical web development.",
    badge: "University",
  },
  {
    command: "work internship --company iFAST",
    output: "Worked around banking-related systems, API testing, CI/CD visibility, logs, and production-style debugging.",
    badge: "2025",
  },
  {
    command: "build ai-interview-assistant --rag",
    output: "Created a resume-aware interview system using embeddings, vector retrieval, LLM prompting, and answer evaluation.",
    badge: "Project",
  },
  {
    command: "focus career --fullstack --ai --backend",
    output: "Improving projects, portfolio, and engineering communication for software engineering roles.",
    badge: "Now",
  },
];
---

<section id="experience" class="bg-[#f8fafc] px-5 py-20 sm:px-10 sm:py-24">
  <div class="mx-auto max-w-7xl">
    <div class="reveal mb-10 grid gap-6 lg:grid-cols-[0.8fr_1.2fr] lg:items-end">
      <div>
        <p class="font-mono text-xs font-black uppercase tracking-[0.25em] text-sky-500">My journey</p>
        <h2 class="mt-3 max-w-2xl font-mono text-3xl font-black tracking-[-0.05em] text-slate-950 sm:text-5xl">
          Experience, but shown like a terminal log.
        </h2>
      </div>
      <p class="max-w-2xl text-base leading-7 text-slate-600 lg:ml-auto">
        A quick view of how I moved from learning software to building projects with production-aware thinking.
      </p>
    </div>

    <div class="reveal overflow-hidden rounded-[1.6rem] border border-sky-100 bg-slate-950 shadow-[0_30px_90px_rgba(15,23,42,.16)] sm:rounded-[2rem]">
      <div class="flex items-center justify-between border-b border-white/10 bg-slate-900 px-4 py-3 sm:px-6">
        <div class="flex gap-2">
          <span class="h-3 w-3 rounded-full bg-red-400"></span>
          <span class="h-3 w-3 rounded-full bg-yellow-300"></span>
          <span class="h-3 w-3 rounded-full bg-green-400"></span>
        </div>
        <p class="font-mono text-xs font-bold text-slate-400">clyde@portfolio:~/journey</p>
      </div>

      <div class="space-y-6 p-5 font-mono sm:p-8">
        {timeline.map((item, index) => (
          <div class="grid gap-3 rounded-2xl border border-white/10 bg-white/[0.03] p-4 sm:grid-cols-[110px_1fr] sm:p-5">
            <div>
              <span class="inline-flex rounded-full bg-sky-400/15 px-3 py-1 text-xs font-black text-purple-600">{item.badge}</span>
            </div>
            <div>
              <p class="break-words text-sm font-bold text-purple-600 sm:text-base">
                <span class="text-green-300">$</span> {item.command}
                {index === timeline.length - 1 && <span class="ml-1 inline-block h-4 w-2 animate-blink bg-sky-200 align-middle"></span>}
              </p>
              <p class="mt-3 text-sm leading-7 text-slate-300">{item.output}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
