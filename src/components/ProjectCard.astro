---
import type { Project } from "../data/projects";
export interface Props { project: Project }
const { project } = Astro.props;
---

<a href={`/projects/${project.slug}`} class="project-card reveal group block overflow-hidden rounded-2xl bg-white text-black shadow-[0_20px_60px_rgba(0,0,0,.08)] transition hover:-translate-y-2 hover:shadow-[0_30px_80px_rgba(0,0,0,.14)]">
  <div class="relative h-52 overflow-hidden bg-neutral-100">
    <img src={project.image} alt={`${project.title} preview`} class="h-full w-full object-cover transition duration-700 group-hover:scale-105" loading="lazy" />
    <span class="absolute left-5 top-5 rounded-full bg-black px-3 py-1.5 text-xs font-bold text-white">{project.category}</span>
  </div>
  <div class="p-6">
    <h3 class="text-xl font-black">{project.title}</h3>
    <p class="mt-3 min-h-[48px] text-sm leading-relaxed text-neutral-600">{project.short}</p>
    <div class="mt-6 flex items-center justify-between text-sm font-black">
      <span>View Case Study</span>
      <span class="text-xl transition group-hover:translate-x-1">→</span>
    </div>
  </div>
</a>
