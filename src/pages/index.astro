---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import Skills from "../components/Skills.astro";
import ProjectCard from "../components/ProjectCard.astro";
import About from "../components/About.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import { projects } from "../data/projects";
---
<BaseLayout>
  <Navbar />
  <main>
    <Hero />
    <Skills />
    <section id="projects" class="bg-[#f6f6f6] py-20">
      <div class="mx-auto max-w-7xl px-6 sm:px-10">
        <div class="reveal mb-10 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="text-sm font-black uppercase tracking-[0.22em] text-neutral-500">Featured Work</p>
            <h2 class="mt-3 font-display text-4xl font-black tracking-tight text-black">Selected projects</h2>
          </div>
          <a href="#projects" class="hidden rounded-full bg-black px-6 py-3 text-xs font-black uppercase text-white sm:inline-block">View all projects</a>
        </div>
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {projects.slice(0,3).map((project) => <ProjectCard project={project} />)}
        </div>
      </div>
    </section>
    <About />
    <Contact />
  </main>
  <Footer />
</BaseLayout>
