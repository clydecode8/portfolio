---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import Experience from "../components/Experience.astro";
import Skills from "../components/Skills.astro";
import ProjectCard from "../components/ProjectCard.astro";
import About from "../components/About.astro";
import Contact from "../components/Contact.astro";
import Footer from "../components/Footer.astro";
import { projects } from "../data/projects";
---
<BaseLayout>
  <Navbar />
  <main>
    <Hero />
    <Experience />
    <Skills />
    <section id="projects" class="bg-[#f8fafc] py-20 sm:py-24">
      <div class="mx-auto max-w-7xl px-5 sm:px-10">
        <div class="reveal mb-10 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
          <div>
            <p class="font-mono text-xs font-black uppercase tracking-[0.25em] text-sky-500">Featured Work</p>
            <h2 class="mt-3 font-mono text-3xl font-black tracking-[-0.05em] text-slate-950 sm:text-5xl">Selected projects</h2>
          </div>
          <a href="#projects" class="hidden rounded-full bg-sky-500 px-6 py-3 font-mono text-xs font-black uppercase text-white transition hover:-translate-y-1 hover:bg-sky-600 sm:inline-block">View all projects</a>
        </div>
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {projects.slice(0,3).map((project) => <ProjectCard project={project} />)}
        </div>
      </div>
    </section>
    <About />
    <Contact />
  </main>
  <Footer />
</BaseLayout>
