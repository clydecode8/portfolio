---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import { projects } from "../../data/projects";

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const nextProjects = projects
  .filter((item) => item.slug !== project.slug)
  .slice(0, 3);
---

<BaseLayout title={`${project.title} — Case Study | Clyde Han`} description={project.short}>
  <Navbar />

  <main class="overflow-hidden bg-[#FDFBF7] text-slate-900">
    <!-- Hero -->
    <section class="relative isolate overflow-hidden px-5 pt-44 sm:px-10 lg:pt-48">
      <div class="pointer-events-none absolute inset-0 -z-10 opacity-[0.35] bg-[linear-gradient(to_right,rgba(15,23,42,.08)_1px,transparent_1px),linear-gradient(to_bottom,rgba(15,23,42,.08)_1px,transparent_1px)] bg-[size:42px_42px]"></div>

      <div class="pointer-events-none absolute left-1/2 top-24 -z-10 h-[32rem] w-[32rem] -translate-x-1/2 rounded-full bg-[radial-gradient(circle,rgba(168,85,247,.20)_0%,rgba(253,251,247,.65)_60%,transparent_75%)] blur-2xl"></div>

      <div class="mx-auto grid max-w-7xl gap-10 pb-20 lg:grid-cols-[0.9fr_1.1fr] lg:items-center">
        <div class="reveal">
          <a
            href="/#projects"
            class="mb-8 inline-flex rounded-full border-2 border-slate-900 bg-white px-5 py-3 font-mono text-xs font-black text-slate-900 shadow-[4px_4px_0_#a855f7] transition hover:-translate-y-1"
          >
            ← Back to all projects
          </a>

          <div class="flex flex-wrap items-center gap-3">

            <p class="font-mono text-xs font-black uppercase tracking-[0.25em] text-purple-600">
              {project.category}
            </p>

            <span class="text-slate-300">
              •
            </span>

            <p class="font-mono text-xs font-black uppercase tracking-[0.25em] text-slate-500">
              {project.date}
            </p>

          </div>

          <h1 class="mt-4 max-w-3xl font-display text-4xl font-black leading-tight tracking-[-0.05em] text-slate-950 sm:text-6xl">
            {project.title}
          </h1>

          <p class="mt-6 max-w-2xl text-base leading-8 text-slate-600 sm:text-lg">
            {
              project.links && (

              <div class="mt-8 flex flex-wrap gap-4">

                {project.links.map((link) => (

                  <a
                    href={link.url}
                    target="_blank"
                    rel="noreferrer"

                    class="
                    inline-flex
                    items-center
                    gap-3

                    rounded-full
                    border-2
                    border-slate-900
                    bg-white

                    px-6
                    py-3

                    font-mono
                    text-sm
                    font-black

                    shadow-[4px_4px_0_#a855f7]

                    transition
                    hover:-translate-y-1
                    hover:shadow-[6px_6px_0_#a855f7]
                    "
                  >

                    <img
                      src={link.icon}
                      alt=""
                      class="h-5 w-5 object-contain"
                    />

                    {link.title}

                  </a>

                ))}

              </div>

              )
            }
          </p>

          <div class="mt-8 grid grid-cols-2 gap-3 sm:grid-cols-4">
            {project.highlights.map((item) => (
              <div class="rounded-2xl border-2 border-slate-900 bg-white p-4 text-center shadow-[4px_4px_0_#a855f7]">
                <div class="mx-auto mb-3 grid h-9 w-9 place-items-center rounded-full bg-purple-100 font-black text-purple-600">
                  ✓
                </div>
                <p class="text-xs font-black leading-snug text-slate-800">
                  {item}
                </p>
              </div>
            ))}
          </div>
        </div>

        <div class="reveal rounded-[1.8rem] border-2 border-slate-900 bg-white p-3 shadow-[8px_8px_0_#a855f7]">
          <img
            src={project.image}
            alt={`${project.title} interface preview`}
            class="h-auto w-full rounded-[1.2rem] object-cover"
          />
        </div>
      </div>
    </section>

    <!-- Problem / Solution -->
    <section class="border-y border-slate-900/10 bg-[#fffefa] px-5 py-16 sm:px-10">
      <div class="mx-auto grid max-w-7xl gap-6 lg:grid-cols-2">
        <div class="reveal rounded-[1.8rem] border-2 border-slate-900 bg-white p-8 shadow-[6px_6px_0_#a855f7]">
          <p class="font-mono text-xs font-black uppercase tracking-[0.22em] text-purple-600">
            The problem
          </p>
          <p class="mt-4 text-base leading-8 text-slate-600 sm:text-lg">
            {project.problem}
          </p>
        </div>

        <div class="reveal rounded-[1.8rem] border-2 border-slate-900 bg-white p-8 shadow-[6px_6px_0_#a855f7]">
          <p class="font-mono text-xs font-black uppercase tracking-[0.22em] text-purple-600">
            The solution
          </p>
          <p class="mt-4 text-base leading-8 text-slate-600 sm:text-lg">
            {project.solution}
          </p>
        </div>
      </div>
    </section>

    <!-- System Flow -->
    <section class="px-5 py-20 sm:px-10">
      <div class="mx-auto max-w-7xl">
        <div class="reveal text-center">
          <p class="font-mono text-xs font-black uppercase tracking-[0.25em] text-purple-600">
            System flow
          </p>
          <h2 class="mt-3 font-display text-4xl font-black tracking-[-0.05em] text-slate-950 sm:text-5xl">
            How it works
          </h2>
        </div>

        <div class="reveal mt-12 flex flex-wrap items-center justify-center gap-3">
          {project.architecture.map((step, index) => (
            <>
              <div class="rounded-2xl border-2 border-slate-900 bg-white px-5 py-4 font-mono text-sm font-black text-slate-800 shadow-[4px_4px_0_#a855f7]">
                {step}
              </div>
              {index < project.architecture.length - 1 && (
                <span class="font-mono text-xl font-black text-purple-600">
                  →
                </span>
              )}
            </>
          ))}
        </div>

        <div class="reveal mt-12 rounded-[1.8rem] border-2 border-slate-900 bg-white p-6 shadow-[6px_6px_0_#a855f7]">
          <h3 class="font-display text-2xl font-black text-slate-950">
            Tech stack
          </h3>

          <div class="mt-5 flex flex-wrap gap-3">
            {project.stack.map((tech) => (
              <span class="rounded-full border border-purple-200 bg-purple-50 px-4 py-2 font-mono text-xs font-black text-purple-700">
                {tech}
              </span>
            ))}
          </div>
        </div>
      </div>
    </section>

    
    </section>

{
project.demos && (

<section class="px-5 py-20 sm:px-10">

  <div class="mx-auto max-w-7xl">

    <!-- Header -->
    <div class="reveal text-center">

      <p class="font-mono text-xs font-black uppercase tracking-[0.25em] text-purple-600">
        Project Demo
      </p>

      <h2 class="mt-3 font-display text-4xl font-black tracking-[-0.05em] text-slate-950 sm:text-5xl">
        User workflows in action.
      </h2>

      <p class="mx-auto mt-5 max-w-2xl text-slate-600">
        Demonstrating the main system flows across different user roles.
      </p>

    </div>



    <!-- Videos -->
    <div class="mt-12 grid gap-8 lg:grid-cols-2">

      {project.demos.map((demo) => (

        <div
          class="
          reveal

          rounded-[2rem]
          border-2
          border-slate-900
          bg-white

          p-4

          shadow-[8px_8px_0_#a855f7]
          "
        >

          <video
            src={demo.video}
            controls
            preload="metadata"
            class="
            aspect-video
            w-full

            rounded-[1.5rem]

            bg-black
            object-cover
            "
          >
          </video>


          <div class="p-3">

            <h3 class="font-display text-xl font-black text-slate-950">
              {demo.title}
            </h3>

            <p class="mt-2 text-sm leading-6 text-slate-600">
              {demo.description}
            </p>

          </div>

        </div>

      ))}

    </div>

  </div>

</section>

)
}

    {
      project.references && (

      <section class="px-5 py-20 sm:px-10">
        <div class="mx-auto max-w-7xl">

          <p class="font-mono text-xs font-black uppercase tracking-[0.25em] text-purple-600">
            Research References
          </p>


          <h2 class="mt-3 font-display text-4xl font-black tracking-[-0.05em] text-slate-950">
            What influenced this project
          </h2>


          <div class="mt-8 grid gap-5">

            {project.references.map((ref) => (

              <a
                href={ref.url}
                target="_blank"
                rel="noreferrer"

                class="
                  rounded-[1.5rem]
                  border-2
                  border-slate-900

                  bg-white

                  p-6

                  shadow-[5px_5px_0_#a855f7]

                  transition
                  hover:-translate-y-1
                  hover:shadow-[7px_7px_0_#a855f7]
                "
              >

                <p class="font-display text-xl font-black text-slate-950">
                  {ref.title}
                </p>


                <p class="mt-2 font-mono text-xs font-bold text-purple-600">
                  {ref.authors}
                </p>

              </a>

            ))}

          </div>

        </div>
      </section>

      )
      }
      
    <!-- More Work -->
    <section class="bg-[#fffefa] px-5 py-20 sm:px-10">
      <div class="mx-auto max-w-7xl">
        <p class="reveal font-mono text-xs font-black uppercase tracking-[0.25em] text-purple-600">
          More work
        </p>

        <h2 class="reveal mt-3 font-display text-4xl font-black tracking-[-0.05em] text-slate-950">
          Other projects
        </h2>

        <div class="mt-8 grid gap-6 md:grid-cols-3">
          {nextProjects.map((item) => (
            <a
              href={`/projects/${item.slug}`}
              class="reveal rounded-[1.6rem] border-2 border-slate-900 bg-white p-5 shadow-[6px_6px_0_#a855f7] transition hover:-translate-y-1 hover:shadow-[8px_8px_0_#a855f7]"
            >
              <img
                src={item.image}
                alt=""
                class="h-36 w-full rounded-xl object-cover"
              />

              <p class="mt-4 font-mono text-xs font-black uppercase tracking-[0.18em] text-purple-600">
                {item.category}
              </p>

              <h3 class="mt-2 text-xl font-black text-slate-950">
                {item.title}
              </h3>

              <p class="mt-2 text-sm leading-6 text-slate-600">
                {item.short}
              </p>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>